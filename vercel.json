{
  "version": 2,
  "builds": [
    { "src": "index.html",      "use": "@vercel/static" },
    { "src": "sw.js",           "use": "@vercel/static" },
    { "src": "manifest.json",   "use": "@vercel/static" },
    { "src": "icon-192.png",    "use": "@vercel/static" },
    { "src": "icon-512x512.png","use": "@vercel/static" },
    { "src": "admin.html",      "use": "@vercel/static" },
    { "src": "privacy.html",    "use": "@vercel/static" },
    { "src": "terms.html",      "use": "@vercel/static" },
    { "src": "reset-password.html","use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/sw.js",  "dest": "/sw.js",  "headers": { "Cache-Control": "no-cache, no-store, must-revalidate" } },
    { "src": "/",       "dest": "/index.html", "headers": { "Cache-Control": "no-cache, no-store, must-revalidate" } },
    { "src": "/(.*)",   "dest": "/$1" }
  ]
}
